# ─────────────────────────────────────────────────────────────────────────────
# Shared .dockerignore for both Dockerfile (frontend) and worker.Dockerfile.
# Keeps the build context small and ensures secrets are NEVER baked into images.
# ─────────────────────────────────────────────────────────────────────────────

# ── Build artefacts (re-created inside Docker) ───────────────────────────────
.next
out
dist
build

# ── Node modules (re-installed inside Docker) ────────────────────────────────
node_modules

# ── Secrets — NEVER bake into any image ──────────────────────────────────────
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.local.example

# ── Git / CI ─────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github

# ── Editor / tooling ─────────────────────────────────────────────────────────
.claude
.vscode
.idea
.DS_Store
*.log
*.pem
npm-debug.log*
yarn-debug.log*

# ── TypeScript / Next.js build metadata ──────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Tests ─────────────────────────────────────────────────────────────────────
__tests__
*.test.*
*.spec.*

# ── gitagent runtime state (not needed at build time) ────────────────────────
agent/.gitagent/
